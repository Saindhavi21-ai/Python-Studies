def details():
    first_name = input("Enter First Name: ")
    last_name = input("Enter Last Name: ")
    username = input("Enter Username: ")
    password = input("Enter Password: ")
    phone_number = input("Enter Phone Number: ")
    recovery_email = input("Enter Recovery Email: ")
    country = input("Enter Country: ")

    return first_name, last_name, username, password, phone_number, recovery_email, country


def display(first_name, last_name, username, password, phone_number, recovery_email, country):

    print("\n----- Gmail Registration Details -----")
    print(f"First Name      : {first_name}")
    print(f"Last Name       : {last_name}")
    print(f"Username        : {username}")
    print(f"Password        : {password}")
    print(f"Phone Number    : {phone_number}")
    print(f"Recovery Email  : {recovery_email}")
    print(f"Country         : {country}")


first_name, last_name, username, password, phone_number, recovery_email, country = details()

display(first_name, last_name, username, password, phone_number, recovery_email, country)
